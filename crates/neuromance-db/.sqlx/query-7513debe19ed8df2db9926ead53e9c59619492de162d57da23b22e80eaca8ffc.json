{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT c.id, c.title, c.status, c.created_at, c.updated_at,\n                   COUNT(m.id) AS \"message_count!\"\n            FROM conversations c\n            LEFT JOIN messages m ON m.conversation_id = c.id\n            GROUP BY c.id\n            ORDER BY c.updated_at DESC\n            LIMIT $1 OFFSET $2\n            ",
